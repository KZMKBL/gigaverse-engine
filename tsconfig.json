{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "forceConsistentCasingInFileNames": true
  },
  
  // 👇 KRİTİK DÜZELTME
  // Sadece src klasöründeki her şeyi dahil et
  "include": ["src/**/*"], 
  
  // Node_modules'e ve projeye ait olmayan diğer dosyalara bakmayı tamamen engelle
  "exclude": ["node_modules", "dist", "src/scripts", "src/scenarios", "src/scripts", "**/*.test.ts", "**/*.spec.ts"]
}
